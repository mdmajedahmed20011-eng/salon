generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
}

enum NotificationType {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  emailVerified     DateTime?
  name              String
  phone             String?
  avatar            String?
  role              Role                 @default(CUSTOMER)
  loyaltyPoints     Int                  @default(0)
  totalSpent        Float                @default(0)
  preferredLocation String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  staffProfile      Staff?
  accounts          Account[]
  sessions          Session[]
  bookings          Booking[]
  reviews           Review[]
  favorites         FavoriteStaff[]
  notifications     Notification[]
  loyaltyHistory    LoyaltyTransaction[]
  usedCoupons       CouponUsage[]
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Location {
  id           String            @id @default(cuid())
  name         String
  slug         String            @unique
  address      String
  city         String
  state        String
  zipCode      String
  country      String            @default("BD")
  phone        String
  email        String
  latitude     Float
  longitude    Float
  images       String[]
  openingHours Json
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  staff        StaffLocation[]
  bookings     Booking[]
  services     LocationService[]
}

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  icon        String
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  services    Service[]
}

model Service {
  id               String            @id @default(cuid())
  categoryId       String
  name             String
  slug             String            @unique
  description      String
  duration         Int
  basePrice        Float
  discountPrice    Float?
  images           String[]
  features         String[]
  isPopular        Boolean           @default(false)
  isFeatured       Boolean           @default(false)
  isActive         Boolean           @default(true)
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  category         ServiceCategory   @relation(fields: [categoryId], references: [id])
  staffServices    StaffService[]
  bookings         BookingService[]
  locationServices LocationService[]
}

model LocationService {
  id         String   @id @default(cuid())
  locationId String
  serviceId  String
  price      Float?
  location   Location @relation(fields: [locationId], references: [id])
  service    Service  @relation(fields: [serviceId], references: [id])

  @@unique([locationId, serviceId])
}

model Staff {
  id           String              @id @default(cuid())
  userId       String?             @unique
  name         String
  slug         String              @unique
  title        String
  bio          String?
  avatar       String?
  images       String[]
  specialties  String[]
  rating       Float               @default(0)
  reviewCount  Int                 @default(0)
  experience   Int
  isActive     Boolean             @default(true)
  instagramUrl String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User?               @relation(fields: [userId], references: [id])
  services     StaffService[]
  locations    StaffLocation[]
  bookings     Booking[]
  reviews      Review[]
  favorites    FavoriteStaff[]
  availability StaffAvailability[]
  breaks       StaffBreak[]
}

model StaffService {
  id            String  @id @default(cuid())
  staffId       String
  serviceId     String
  priceOverride Float?
  staff         Staff   @relation(fields: [staffId], references: [id])
  service       Service @relation(fields: [serviceId], references: [id])

  @@unique([staffId, serviceId])
}

model StaffLocation {
  id         String   @id @default(cuid())
  staffId    String
  locationId String
  staff      Staff    @relation(fields: [staffId], references: [id])
  location   Location @relation(fields: [locationId], references: [id])

  @@unique([staffId, locationId])
}

model StaffAvailability {
  id        String  @id @default(cuid())
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isWorking Boolean @default(true)
  staff     Staff   @relation(fields: [staffId], references: [id])
}

model StaffBreak {
  id        String  @id @default(cuid())
  staffId   String
  startTime String
  endTime   String
  dayOfWeek Int?
  staff     Staff   @relation(fields: [staffId], references: [id])
}

model Booking {
  id              String        @id @default(cuid())
  userId          String
  staffId         String
  locationId      String
  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  appointmentDate DateTime
  startTime       String
  endTime         String
  totalDuration   Int
  subtotal        Float
  discountAmount  Float         @default(0)
  taxAmount       Float         @default(0)
  totalAmount     Float
  stripePaymentId String?
  couponId        String?
  notes           String?
  reminderSent24h Boolean       @default(false)
  reminderSent1h  Boolean       @default(false)
  cancelledAt     DateTime?
  cancelReason    String?
  rescheduledFrom String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  staff           Staff         @relation(fields: [staffId], references: [id])
  location        Location      @relation(fields: [locationId], references: [id])
  services        BookingService[]
  review          Review?
  coupon          Coupon?       @relation(fields: [couponId], references: [id])
  notifications   Notification[]
}

model BookingService {
  id        String  @id @default(cuid())
  bookingId String
  serviceId String
  price     Float
  duration  Int
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  staffId    String
  bookingId  String   @unique
  rating     Float
  title      String?
  body       String
  images     String[]
  isVerified Boolean  @default(true)
  isPublic   Boolean  @default(true)
  adminReply String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
  staff      Staff    @relation(fields: [staffId], references: [id])
  booking    Booking  @relation(fields: [bookingId], references: [id])
}

model FavoriteStaff {
  id      String @id @default(cuid())
  userId  String
  staffId String
  user    User   @relation(fields: [userId], references: [id])
  staff   Staff  @relation(fields: [staffId], references: [id])

  @@unique([userId, staffId])
}

model Coupon {
  id                 String        @id @default(cuid())
  code               String        @unique
  description        String
  discountType       String
  discountValue      Float
  minOrderAmount     Float?
  maxDiscount        Float?
  usageLimit         Int?
  usedCount          Int           @default(0)
  validFrom          DateTime
  validUntil         DateTime
  isActive           Boolean       @default(true)
  applicableServices String[]
  createdAt          DateTime      @default(now())
  usages             CouponUsage[]
  bookings           Booking[]
}

model CouponUsage {
  id       String   @id @default(cuid())
  couponId String
  userId   String
  usedAt   DateTime @default(now())
  coupon   Coupon   @relation(fields: [couponId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@unique([couponId, userId])
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  userId      String
  points      Int
  type        String
  description String
  bookingId   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  bookingId String?
  type      NotificationType
  subject   String
  content   String
  isSent    Boolean          @default(false)
  sentAt    DateTime?
  error     String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
  booking   Booking?         @relation(fields: [bookingId], references: [id])
}

model SalonSettings {
  id                     String   @id @default(cuid())
  salonName              String
  logoUrl                String?
  primaryColor           String   @default("#D4A017")
  bookingAdvanceDays     Int      @default(30)
  cancellationHours      Int      @default(24)
  loyaltyPointsPerDollar Float    @default(10)
  taxRate                Float    @default(0)
  stripePublishableKey   String?
  googleAnalyticsId      String?
  whatsappNumber         String?
  updatedAt              DateTime @updatedAt
}
